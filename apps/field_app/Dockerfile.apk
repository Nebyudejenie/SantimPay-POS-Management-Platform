# Builds the Flutter field app into a release APK inside a container (the VM has no Flutter SDK).
# Output: /output/app-release.apk (extracted by the build script). Multi-step: scaffold android files,
# run codegen (freezed/json/drift/retrofit), then build the APK.
FROM ghcr.io/cirruslabs/flutter:3.29.2 AS build
WORKDIR /app
# Accept Android SDK licenses + ensure SDK 35 is present (a plugin requires it).
RUN yes | flutter doctor --android-licenses >/dev/null 2>&1 || true; \
    yes | sdkmanager "platforms;android-35" "build-tools;35.0.0" >/dev/null 2>&1 || true

# Pre-cache deps using just the manifest for better layer reuse.
COPY pubspec.yaml ./
RUN flutter pub get || true

# Bring in the source.
COPY . .

# The project ships source-only (no android/ ios/). Generate the platform scaffolding in place,
# then re-get deps, run code generation, and build the release APK.
RUN set -e; \
    flutter create --platforms=android --project-name posctl_field --overwrite . ; \
    flutter pub get ; \
    flutter pub add --dev build_runner ; \
    flutter pub run build_runner build --delete-conflicting-outputs ; \
    flutter build apk --release --no-tree-shake-icons \
      --dart-define=API_BASE_URL=https://192.168.1.40:8443/api/v1 \
      --dart-define=OIDC_ISSUER=https://192.168.1.40:8443/auth/realms/posctl \
      --dart-define=OIDC_CLIENT_ID=posctl-field

# Tiny final stage just holds the artifact for easy extraction.
FROM alpine:3 AS artifact
COPY --from=build /app/build/app/outputs/flutter-apk/app-release.apk /app-release.apk
