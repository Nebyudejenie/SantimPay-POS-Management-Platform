{
  "realm": "posctl",
  "enabled": true,
  "displayName": "SantimPay POS",
  "sslRequired": "external",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "bruteForceProtected": true,
  "accessTokenLifespan": 900,
  "ssoSessionIdleTimeout": 1800,
  "ssoSessionMaxLifespan": 36000,
  "roles": {
    "realm": [
      {
        "name": "SUPER_ADMIN",
        "description": "Full system + user administration"
      },
      {
        "name": "OPS_MANAGER",
        "description": "Inventory, deployments, approvals, reporting"
      },
      {
        "name": "CALL_CENTER",
        "description": "Follow-ups, KYC intake, lookups"
      },
      {
        "name": "FIELD_OFFICER",
        "description": "Field deployments (region-scoped)"
      },
      {
        "name": "FINANCE",
        "description": "Settlement + commission reports, settlement KYC approve"
      },
      {
        "name": "COMPLIANCE",
        "description": "Read-all + KYC/compliance approve"
      },
      {
        "name": "DATA_ENCODER",
        "description": "Merchant/branch/deployment intake"
      },
      {
        "name": "IT_ADMIN",
        "description": "System config / integrations"
      }
    ],
    "client": {
      "posctl-api": [
        {
          "name": "merchant:read"
        },
        {
          "name": "merchant:create"
        },
        {
          "name": "merchant:update"
        },
        {
          "name": "merchant:approve"
        },
        {
          "name": "device:read"
        },
        {
          "name": "device:create"
        },
        {
          "name": "device:update"
        },
        {
          "name": "device:assign"
        },
        {
          "name": "device:retire"
        },
        {
          "name": "device:telemetry"
        },
        {
          "name": "deployment:read"
        },
        {
          "name": "deployment:create"
        },
        {
          "name": "deployment:complete"
        },
        {
          "name": "kyc:read"
        },
        {
          "name": "kyc:review"
        },
        {
          "name": "kyc:approve"
        },
        {
          "name": "workflow:read"
        },
        {
          "name": "workflow:approve"
        },
        {
          "name": "task:read"
        },
        {
          "name": "task:create"
        },
        {
          "name": "task:update"
        },
        {
          "name": "task:assign"
        },
        {
          "name": "followup:read"
        },
        {
          "name": "followup:create"
        },
        {
          "name": "report:read"
        },
        {
          "name": "report:export"
        },
        {
          "name": "user:manage"
        },
        {
          "name": "pii:read"
        }
      ]
    }
  },
  "clients": [
    {
      "clientId": "posctl-web",
      "name": "POS Web Console (React SPA)",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "rootUrl": "https://app.posctl.santimpay.com",
      "redirectUris": [
        "https://app.posctl.santimpay.com/*",
        "http://localhost:5173/*",
        "https://192.168.1.40:8443/*"
      ],
      "webOrigins": [
        "https://app.posctl.santimpay.com",
        "http://localhost:5173",
        "https://192.168.1.40:8443"
      ],
      "attributes": {
        "pkce.code.challenge.method": "S256"
      },
      "defaultClientScopes": [
        "profile",
        "email",
        "roles"
      ],
      "protocolMappers": [
        {
          "name": "permissions-from-client-roles",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-client-role-mapper",
          "consentRequired": false,
          "config": {
            "usermodel.clientRoleMapping.clientId": "posctl-api",
            "claim.name": "permissions",
            "jsonType.label": "String",
            "multivalued": "true",
            "access.token.claim": "true",
            "id.token.claim": "false"
          }
        },
        {
          "name": "uid-mapper",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "uid",
            "claim.name": "uid",
            "jsonType.label": "String",
            "access.token.claim": "true",
            "id.token.claim": "true"
          }
        }
      ]
    },
    {
      "clientId": "posctl-field",
      "name": "POS Field App (Flutter)",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "redirectUris": [
        "com.santimpay.posctl:/oauth2redirect",
        "http://localhost:*"
      ],
      "attributes": {
        "pkce.code.challenge.method": "S256"
      },
      "defaultClientScopes": [
        "profile",
        "email",
        "roles"
      ],
      "protocolMappers": [
        {
          "name": "permissions-from-client-roles",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-client-role-mapper",
          "consentRequired": false,
          "config": {
            "usermodel.clientRoleMapping.clientId": "posctl-api",
            "claim.name": "permissions",
            "jsonType.label": "String",
            "multivalued": "true",
            "access.token.claim": "true",
            "id.token.claim": "false"
          }
        }
      ]
    },
    {
      "clientId": "posctl-api",
      "name": "POS Backend API (resource server)",
      "enabled": true,
      "bearerOnly": true,
      "publicClient": false,
      "description": "Resource-server client. Its CLIENT ROLES are the fine-grained resource:action permissions (defined under realm roles.client), mapped into the `permissions` token claim."
    }
  ],
