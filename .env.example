# Copy to .env for local dev. Production values come from Vault via External Secrets.
# ---- Database ----
POSTGRES_URL=jdbc:postgresql://localhost:5432/posctl
POSTGRES_USER=posctl
POSTGRES_PASSWORD=posctl

# ---- Redis ----
REDIS_HOST=localhost
REDIS_PORT=6379

# ---- MinIO (S3) ----
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=posctl
S3_SECRET_KEY=posctlsecret
S3_BUCKET=posctl-attachments

# ---- Keycloak (OIDC) ----
OIDC_ISSUER_URI=http://localhost:8081/realms/posctl
OIDC_AUDIENCE=posctl-api

# ---- App ----
SPRING_PROFILES_ACTIVE=dev
